{
  "name": "hiresight",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && vite preview",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 execute hiring_db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute hiring_db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.11.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.9.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "wrangler": "^4.100.0"
  }
}
